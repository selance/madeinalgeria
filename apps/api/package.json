{
  "name": "@mia/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "db:migrate:local": "wrangler d1 migrations apply mia-core --local",
    "db:migrate:staging": "wrangler d1 migrations apply mia-core-staging --env staging --remote",
    "db:migrate:production": "wrangler d1 migrations apply mia-core-prod --env production --remote",
    "seed:local": "wrangler d1 execute mia-core --local --file ../../tools/seed/core.sql",
    "seed:staging": "wrangler d1 execute mia-core-staging --env staging --remote --file ../../tools/seed/core.sql",
    "seed:production": "wrangler d1 execute mia-core-prod --env production --remote --file ../../tools/seed/core.sql",
    "seed:projects:local": "wrangler d1 execute mia-core --local --file ../../tools/seed/projects.sql",
    "seed:projects:staging": "wrangler d1 execute mia-core-staging --env staging --remote --file ../../tools/seed/projects.sql",
    "seed:projects:production": "wrangler d1 execute mia-core-prod --env production --remote --file ../../tools/seed/projects.sql",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test",
    "test": "vitest run"
  },
  "dependencies": {
    "@mia/auth": "workspace:*",
    "@mia/contracts": "workspace:*",
    "@mia/core": "workspace:*",
    "@mia/db-core": "workspace:*",
    "@mia/email": "workspace:*",
    "@mia/module-billing": "workspace:*",
    "@mia/module-identity": "workspace:*",
    "@mia/module-notifications": "workspace:*",
    "@mia/module-projects": "workspace:*",
    "@mia/module-reference": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.11",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.0",
    "wrangler": "^4.20.0"
  }
}
