---
import { apiGet } from "../lib/api";
import { loadCategories, categoryName } from "../lib/reference";
import { localizePath, ui, type Locale } from "../lib/i18n";
import type {
  ProjectLanguageFacet,
  ProjectOwnerFacet,
  ProjectTopicFacet,
} from "@mia/contracts";

/**
 * "Browse the directory" — the internal-link hub that flattens crawl depth: it
 * links every category, top languages/topics, and top developers from one
 * compact block (two columns on desktop). Rendered on the home page and the
 * projects index. All fetches are KV-cached upstream and failure-tolerant.
 */
interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];
const env = Astro.locals.runtime?.env;

const [categories, langRes, topicRes, ownerRes] = await Promise.all([
  loadCategories(env),
  apiGet<{ languages: ProjectLanguageFacet[] }>(env, "/v1/projects/facets"),
  apiGet<{ topics: ProjectTopicFacet[] }>(env, "/v1/projects/facets/topics"),
  apiGet<{ owners: ProjectOwnerFacet[] }>(env, "/v1/projects/facets/owners"),
]);

const languages = (langRes.data?.languages ?? []).slice(0, 10);
const topics = (topicRes.data?.topics ?? []).slice(0, 12);
const developers = (ownerRes.data?.owners ?? []).slice(0, 8);

const chip =
  "rounded-md border !border-neutral-200 bg-white px-2.5 py-1 text-xs text-neutral-600 transition-colors hover:!border-primary-300 hover:text-primary-600";
const quickLink = "text-primary-600 hover:text-primary-700 text-sm font-semibold";
---

<section class="mx-auto w-full max-w-7xl px-6 py-10">
  <div class="mb-6">
    <h2 class="text-xl font-bold text-neutral-900 md:text-2xl">{t.hubs.browseTitle}</h2>
    <p class="text-sm text-neutral-500">{t.hubs.browseBody}</p>
  </div>

  <div class="grid grid-cols-1 gap-x-10 gap-y-6 sm:grid-cols-2">
    {
      categories.length > 0 && (
        <div>
          <h3 class="mb-2.5 text-xs font-semibold uppercase tracking-wide text-neutral-400">
            {t.hubs.byCategory}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {categories.map((c) => (
              <a href={localizePath(`/projects/category/${c.slug}`, locale)} class={chip}>
                {categoryName(c, locale)}
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      languages.length > 0 && (
        <div>
          <h3 class="mb-2.5 text-xs font-semibold uppercase tracking-wide text-neutral-400">
            {t.hubs.byLanguage}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {languages.map((l) => (
              <a
                href={localizePath(`/projects/language/${encodeURIComponent(l.name)}`, locale)}
                dir="ltr"
                class={chip}
              >
                {l.name}
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      topics.length > 0 && (
        <div>
          <h3 class="mb-2.5 text-xs font-semibold uppercase tracking-wide text-neutral-400">
            {t.hubs.byTopic}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {topics.map((tp) => (
              <a
                href={localizePath(`/projects/topic/${encodeURIComponent(tp.topic)}`, locale)}
                dir="ltr"
                class={chip}
              >
                {tp.topic}
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      developers.length > 0 && (
        <div>
          <h3 class="mb-2.5 text-xs font-semibold uppercase tracking-wide text-neutral-400">
            {t.hubs.byDeveloper}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {developers.map((d) => (
              <a href={localizePath(`/developers/${d.login}`, locale)} dir="ltr" class={chip}>
                @{d.login}
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>

  <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 border-t !border-neutral-200 pt-5">
    <a href={localizePath("/projects/top", locale)} class={quickLink}>{t.hubs.topTitle}</a>
    <span aria-hidden class="text-neutral-300">·</span>
    <a href={localizePath("/projects/new", locale)} class={quickLink}>{t.hubs.newTitle}</a>
    <span aria-hidden class="text-neutral-300">·</span>
    <a href={localizePath("/developers", locale)} class={quickLink}>{t.hubs.developersTitle}</a>
    <span aria-hidden class="text-neutral-300">·</span>
    <a href={localizePath("/projects", locale)} class={quickLink}>{t.hubs.viewAll}</a>
  </div>
</section>
