---
import Base from "../../layouts/Base.astro";
import { localizePath, ui, type Locale } from "../../lib/i18n";
import { buttonVariants, cn } from "@mia/ui";

/** Shared not-found shell for hub routes with an unknown filter (404, noindex). */
interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];
---

<Base title={`${t.notFound.title} — ${t.siteName}`} description={t.notFound.body} locale={locale} noindex>
  <section class="mx-auto w-full max-w-4xl px-6 py-16 md:py-24">
    <div class="rounded-card border !border-neutral-200 bg-white p-14 text-center">
      <h1 class="mb-2 text-2xl font-bold text-neutral-900">{t.notFound.title}</h1>
      <p class="mb-6 text-neutral-500">{t.notFound.body}</p>
      <a href={localizePath("/projects", locale)} class={cn(buttonVariants())}>{t.hubs.viewAll}</a>
    </div>
  </section>
</Base>
