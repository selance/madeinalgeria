---
import Base from "../../layouts/Base.astro";
import { compactCount } from "../react/ProjectCard";
import { localizePath, ui, type Locale } from "../../lib/i18n";
import { breadcrumbJsonLd, projectJsonLd } from "../../lib/jsonld";
import { loadCategories, categoryName } from "../../lib/reference";
import { SITE } from "../../lib/site";
import { buttonVariants, cn } from "@mia/ui";
import { formatDateAr } from "@mia/core";
import type { PublicProject } from "@mia/contracts";
import GithubIcon from "@mia/ui/icons/GithubIcon";
import RatingStarIcon from "@mia/ui/icons/RatingStarIcon";
import GlobIcon from "@mia/ui/icons/GlobIcon";

interface Props {
  locale: Locale;
  slug: string;
  /** Loaded by the route wrapper (which also sets the HTTP status). */
  project: PublicProject | null;
}

const { locale, slug, project } = Astro.props;
const t = ui[locale];
const sep = locale === "ar" ? "، " : ", ";

// Resolve the project's category (for a breadcrumb + an internal hub link).
const categories = project?.categoryId ? await loadCategories(Astro.locals.runtime?.env) : [];
const category = project?.categoryId
  ? categories.find((c) => c.id === project.categoryId)
  : undefined;
const catName = category ? categoryName(category, locale) : null;

const crumbs = project
  ? [
      { name: t.breadcrumb.home, path: "/" },
      { name: t.breadcrumb.projects, path: "/projects" },
      ...(category && catName
        ? [{ name: catName, path: `/projects/category/${category.slug}` }]
        : []),
      { name: project.name, path: `/projects/${project.slug}` },
    ]
  : [];

// README badge embed — an honest backlink from the repo back to its listing.
const badgeSrc = project ? `${SITE}/badge/${project.slug}.svg` : "";
const projectUrl = project ? `${SITE}/projects/${project.slug}` : "";
const badgeMarkdown = project
  ? `[![Made in Algeria](${badgeSrc})](${projectUrl})`
  : "";

const description =
  project && locale === "ar" && project.descriptionAr
    ? project.descriptionAr
    : (project?.description ?? "");
const lastPush = project?.repoPushedAt
  ? locale === "ar"
    ? formatDateAr(project.repoPushedAt)
    : new Date(project.repoPushedAt).toLocaleDateString("en-GB", { dateStyle: "medium" })
  : null;

// Language moves out of the plain facts grid into a linked "browse" chip below.
const facts: { label: string; value: string }[] = project
  ? [
      { label: t.detail.stars, value: project.stars.toLocaleString("en") },
      { label: t.detail.forks, value: project.forks.toLocaleString("en") },
      ...(project.license ? [{ label: t.detail.license, value: project.license }] : []),
      ...(lastPush ? [{ label: t.detail.lastPush, value: lastPush }] : []),
    ]
  : [];
---

<Base
  title={project ? `${project.name}${sep}${t.siteName}` : `${t.notFound.title}${sep}${t.siteName}`}
  description={project ? description || t.projects.description : t.notFound.body}
  locale={locale}
  canonicalPath={localizePath(`/projects/${slug}`, locale)}
  noindex={!project}
  jsonLd={project
    ? [...projectJsonLd(project, description, locale), breadcrumbJsonLd(crumbs, locale)]
    : undefined}
>
  <section class="mx-auto w-full max-w-4xl px-6 py-10 md:py-14">
    <a
      href={localizePath("/projects", locale)}
      class="mb-6 inline-block text-sm font-semibold text-primary-600 hover:text-primary-700"
    >
      {t.detail.backToProjects}
    </a>

    {
      project ? (
        <article class="rounded-card border !border-neutral-200 bg-white p-6 md:p-10">
          <header class="mb-6 flex flex-wrap items-start justify-between gap-4">
            <div class="flex items-center gap-4">
              {project.ownerAvatarUrl ? (
                <img
                  src={project.ownerAvatarUrl}
                  alt=""
                  class="size-14 rounded-full border !border-neutral-200"
                />
              ) : (
                <span class="bg-primary-50 text-primary-600 flex size-14 items-center justify-center rounded-full text-xl font-bold">
                  {project.ownerLogin.charAt(0).toUpperCase()}
                </span>
              )}
              <div>
                <h1 class="text-2xl font-extrabold text-neutral-900 md:text-3xl">
                  {project.name}
                </h1>
                <p class="text-sm text-neutral-500">
                  {t.detail.by}{" "}
                  {/* Internal profile hub (keeps users on-site + feeds crawl depth). */}
                  <a
                    href={localizePath(`/developers/${project.ownerLogin}`, locale)}
                    dir="ltr"
                    class="font-semibold text-primary-600 hover:text-primary-700"
                  >
                    @{project.ownerLogin}
                  </a>
                </p>
              </div>
            </div>
            <div class="flex flex-wrap items-center gap-2">
              {(project.isArchived || project.isActive) && (
                <span
                  class:list={[
                    "rounded-md px-2.5 py-1 text-xs font-semibold",
                    project.isArchived
                      ? "bg-neutral-200 text-neutral-600"
                      : "bg-success-50 text-success-700",
                  ]}
                >
                  {project.isArchived ? t.projects.archived : t.projects.active}
                </span>
              )}
              <span class="flex items-center gap-1 rounded-md bg-warning-50 px-2.5 py-1 text-xs font-semibold text-warning-700">
                <RatingStarIcon className="fill-warning-400 size-3.5" />
                {compactCount(project.stars)}
              </span>
            </div>
          </header>

          {description && (
            <p class="mb-8 max-w-3xl text-lg leading-relaxed text-neutral-600">{description}</p>
          )}

          {/* Browse chips — internal hubs the crawler follows from this spoke. */}
          {(catName || project.primaryLanguage) && (
            <div class="mb-8 flex flex-wrap gap-2">
              {category && catName && (
                <a
                  href={localizePath(`/projects/category/${category.slug}`, locale)}
                  class="bg-primary-50 text-primary-700 hover:bg-primary-100 rounded-md px-2.5 py-1 text-xs font-semibold transition-colors"
                >
                  {catName}
                </a>
              )}
              {project.primaryLanguage && (
                <a
                  href={localizePath(
                    `/projects/language/${encodeURIComponent(project.primaryLanguage)}`,
                    locale,
                  )}
                  dir="ltr"
                  class="rounded-md bg-neutral-100 px-2.5 py-1 text-xs font-semibold text-neutral-700 transition-colors hover:bg-neutral-200"
                >
                  {project.primaryLanguage}
                </a>
              )}
            </div>
          )}

          <dl class="mb-8 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-5">
            {facts.map((fact) => (
              <div class="rounded-md bg-neutral-100 p-3">
                <dt class="text-xs text-neutral-400">{fact.label}</dt>
                <dd class="font-bold text-neutral-800" dir="ltr">
                  {fact.value}
                </dd>
              </div>
            ))}
          </dl>

          {project.topics.length > 0 && (
            <div class="mb-8">
              <h2 class="mb-2 text-sm font-semibold text-neutral-500">{t.detail.topics}</h2>
              <div class="flex flex-wrap gap-2">
                {project.topics.map((topic) => (
                  <a
                    href={localizePath(`/projects/topic/${encodeURIComponent(topic)}`, locale)}
                    dir="ltr"
                    class="bg-primary-50 text-primary-700 hover:bg-primary-100 rounded-md px-2.5 py-1 text-xs font-medium transition-colors"
                  >
                    {topic}
                  </a>
                ))}
              </div>
            </div>
          )}

          <div class="flex flex-wrap gap-3">
            <a
              href={project.htmlUrl}
              target="_blank"
              rel="noreferrer"
              class={cn(buttonVariants({ size: "lg" }), "gap-2 px-6")}
            >
              <GithubIcon className="size-4 fill-current" />
              {t.detail.viewOnGitHub}
            </a>
            {project.homepage && (
              <a
                href={project.homepage}
                target="_blank"
                rel="noreferrer"
                class={cn(buttonVariants({ variant: "dark-ghost", size: "lg" }), "gap-2 px-6")}
              >
                <GlobIcon className="size-4 fill-current" />
                {t.detail.website}
              </a>
            )}
          </div>

          {/* Embeddable README badge — a compounding, value-first backlink. */}
          <div class="mt-10 border-t !border-neutral-200 pt-6">
            <h2 class="mb-1 text-sm font-semibold text-neutral-500">{t.detail.badgeTitle}</h2>
            <p class="mb-3 text-sm text-neutral-400">{t.detail.badgeHint}</p>
            <img src={badgeSrc} alt="Made in Algeria" height="20" class="mb-3" loading="lazy" />
            <pre
              dir="ltr"
              class="overflow-x-auto rounded-md bg-neutral-100 p-3 text-start text-xs text-neutral-700"
            ><code>{badgeMarkdown}</code></pre>
          </div>
        </article>
      ) : (
        <div class="rounded-card border !border-neutral-200 bg-white p-14 text-center">
          <h1 class="mb-2 text-2xl font-bold text-neutral-900">{t.notFound.title}</h1>
          <p class="mb-6 text-neutral-500">{t.notFound.body}</p>
          <a href={localizePath("/projects", locale)} class={cn(buttonVariants())}>
            {t.detail.backToProjects}
          </a>
        </div>
      )
    }
  </section>
</Base>
