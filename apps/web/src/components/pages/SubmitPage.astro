---
import Base from "../../layouts/Base.astro";
import SubmitProjectForm from "../react/SubmitProjectForm";
import { localizePath, ui, type Locale } from "../../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];
---

<Base
  title={`${t.submit.title} — ${t.siteName}`}
  description={t.submit.description}
  locale={locale}
  canonicalPath={localizePath("/submit", locale)}
>
  <section class="mx-auto w-full max-w-2xl px-6 py-12 md:py-16">
    <h1 class="mb-3 text-3xl font-extrabold text-neutral-900 md:text-4xl">{t.submit.heading}</h1>
    <p class="mb-10 leading-relaxed text-neutral-500">{t.submit.intro}</p>
    <div class="rounded-card border !border-neutral-200 bg-white p-6 md:p-8">
      <SubmitProjectForm client:load locale={locale} />
    </div>
  </section>
</Base>
