---
import HubListPage from "../../../../components/pages/HubListPage.astro";
import HubNotFound from "../../../../components/pages/HubNotFound.astro";
import { loadCategoryHub, pageParam } from "../../../../lib/hub";
export const prerender = false;

const view = await loadCategoryHub(
  Astro.locals.runtime?.env,
  "ar",
  Astro.params.slug ?? "",
  pageParam(Astro.url),
);
if (!view) Astro.response.status = 404;
---

{view ? <HubListPage {...view} /> : <HubNotFound locale="ar" />}
