---
import HubListPage from "../../components/pages/HubListPage.astro";
import HubNotFound from "../../components/pages/HubNotFound.astro";
import { loadDeveloperHub, pageParam } from "../../lib/hub";
export const prerender = false;

const view = await loadDeveloperHub(
  Astro.locals.runtime?.env,
  "en",
  Astro.params.login ?? "",
  pageParam(Astro.url),
);
if (!view) Astro.response.status = 404;
---

{view ? <HubListPage {...view} /> : <HubNotFound locale="en" />}
